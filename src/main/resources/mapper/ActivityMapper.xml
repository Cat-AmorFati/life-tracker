<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yuhang.lifetracker.mapper.ActivityMapper">

    <insert id="insert" parameterType="com.yuhang.lifetracker.entity.Activity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO activity_log (content, category, create_time)
        VALUES (#{content}, #{category}, #{createTime})
    </insert>

    <select id="findAll" resultType="com.yuhang.lifetracker.entity.Activity">
        SELECT id, content, category, create_time as createTime
        FROM activity_log
        ORDER BY create_time DESC
    </select>

    <delete id="deleteById">
        DELETE FROM activity_log WHERE id = #{id}
    </delete>

</mapper>
